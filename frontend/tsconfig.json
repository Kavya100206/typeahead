{
  "compilerOptions": {
    // Compile to modern JS that every current browser runs natively.
    "target": "ES2020",
    // Emit native ES modules (import/export), loaded via <script type="module">.
    // This is why source imports use the ".js" extension.
    "module": "ES2020",
    "moduleResolution": "bundler",

    // src/*.ts  ->  dist/*.js
    "rootDir": "./src",
    "outDir": "./dist",

    // Catch mistakes early; easier to defend in a viva than loose settings.
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
